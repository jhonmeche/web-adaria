---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import Problema from '../components/sections/Problema.astro';
import Solucion from '../components/sections/Solucion.astro';
import Stack from '../components/sections/Stack.astro';
import Sectores from '../components/sections/Sectores.astro';
import CasoSmartPBA from '../components/sections/CasoSmartPBA.astro';
import PorQue from '../components/sections/PorQue.astro';
import Contacto from '../components/sections/Contacto.astro';

const title = 'AdariA Systems — Soluciones tecnológicas a la medida de tu industria';
const description =
  'Visión artificial, IoT/LoRa y hardware propio bajo un mismo techo. Del sensor a la decisión, a la medida, con dato auditable. Agenda una demo.';
---

<BaseLayout title={title} description={description}>
  <Hero />
  <Problema />
  <Solucion />
  <Stack />
  <Sectores />
  <CasoSmartPBA />
  <PorQue />
  <Contacto />
</BaseLayout>
