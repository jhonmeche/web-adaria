---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/ui/Section.astro';
import Eyebrow from '../../components/ui/Eyebrow.astro';
import Button from '../../components/ui/Button.astro';
import { productos } from '../../data/productos.ts';
import { sectores } from '../../data/sectores.ts';

export function getStaticPaths() {
  return productos
    .filter((p) => p.detalle)
    .map((p) => ({ params: { slug: p.slug }, props: { producto: p } }));
}

const { producto } = Astro.props;
const d = producto.detalle!;

// Sectores relacionados (resuelve slugs → objeto sector para mostrar el nombre).
const relacionados = (d.sectores ?? [])
  .map((slug) => sectores.find((s) => s.slug === slug))
  .filter(Boolean);

// Aplicaciones por sector: casos de uso concretos por industria (resuelve el
// objeto sector para nombre y color). Si existe, manda sobre las píldoras.
const aplicaciones = (d.aplicaciones ?? [])
  .map((a) => ({ ...a, info: sectores.find((s) => s.slug === a.sector) }))
  .filter((a) => a.info);

// Los otros productos del stack (cross-sell: "un solo aliado", land & expand §6).
const otros = productos.filter((p) => p.detalle && p.slug !== producto.slug);

const title = `${producto.nombre} — ${producto.categoria} | AdariA Systems`;
const description = producto.descripcion;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();

// Datos estructurados para SEO (rich results en buscadores).
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Product',
      name: producto.nombre,
      category: producto.categoria,
      description: producto.descripcion,
      brand: { '@type': 'Brand', name: 'AdariA Systems' },
      url: canonical,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Inicio', item: new URL('/', Astro.site).toString() },
        { '@type': 'ListItem', position: 2, name: 'Productos', item: new URL('/#productos', Astro.site).toString() },
        { '@type': 'ListItem', position: 3, name: producto.nombre, item: canonical },
      ],
    },
  ],
};
---

<BaseLayout title={title} description={description}>
  <!-- HERO -->
  <section class="relative isolate overflow-hidden bg-ink text-on-dark">
    <div class="tech-grid pointer-events-none absolute inset-0 opacity-50" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-6xl px-6 pb-20 pt-36 lg:px-8 lg:pt-40">
      <!-- Breadcrumb -->
      <nav class="mb-8 flex items-center gap-2 text-sm text-muted-dark" aria-label="Ruta">
        <a href="/" class="transition-colors hover:text-on-dark">Inicio</a>
        <span aria-hidden="true">/</span>
        <a href="/#productos" class="transition-colors hover:text-on-dark">Productos</a>
        <span aria-hidden="true">/</span>
        <span class="text-on-dark" aria-current="page">{producto.nombre}</span>
      </nav>

      <div class="grid items-center gap-12 lg:grid-cols-[1.2fr_1fr]">
        <div>
          <span class="inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-brand text-white shadow-lg shadow-brand/30">
            <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d={producto.icon} stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
          <p class="mt-6 text-base font-semibold text-brand-400">{producto.categoria}</p>
          <h1 class="mt-2 text-display font-semibold text-on-dark">{producto.nombre}</h1>
          <p class="mt-4 text-balance text-h2 font-semibold text-on-dark">{producto.tagline}</p>
          <p class="mt-6 max-w-xl text-lg leading-relaxed text-muted-dark">{d.intro}</p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:items-center">
            <Button href="/#contacto" variant="primary" on="dark">Hable con un experto</Button>
            <Button href="/#productos" variant="secondary" on="dark">Ver todos los productos</Button>
          </div>
        </div>

        <!-- Puntos clave destacados -->
        <ul class="grid gap-3">
          {producto.puntos.map((pt) => (
            <li class="flex items-start gap-3 rounded-2xl border border-white/10 bg-ink-card p-5 ring-1 ring-white/5">
              <svg class="mt-0.5 h-5 w-5 shrink-0 text-brand-400" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 10.5 8 14l8-8.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span class="text-sm font-medium text-on-dark">{pt}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- CAPACIDADES / LÍNEAS -->
  <Section theme="light" id="capacidades">
    <div class="mx-auto max-w-3xl text-center">
      <Eyebrow on="light">Capacidades</Eyebrow>
      <h2 data-reveal class="text-balance text-h1 font-semibold text-on-light">{d.capacidadesTitulo}</h2>
      {d.capacidadesIntro && (
        <p data-reveal class="mt-5 text-lg leading-relaxed text-muted">{d.capacidadesIntro}</p>
      )}
    </div>

    <div class="mt-16 grid gap-6 md:grid-cols-2">
      {d.capacidades.map((c, i) => (
        <article
          data-reveal
          class="card flex flex-col rounded-2xl border border-ink/10 bg-surface p-8 shadow-sm ring-1 ring-ink/5 hover:[translate:0_-6px] hover:border-brand/30 hover:shadow-lg"
          style={`--reveal-delay:${i * 80}ms`}
        >
          <h3 class="text-xl font-semibold text-on-light">{c.titulo}</h3>
          {c.descripcion && <p class="mt-1 text-sm font-medium text-brand">{c.descripcion}</p>}
          <ul class="mt-5 grid gap-2.5 border-t border-ink/5 pt-5">
            {c.items.map((it) => (
              <li class="flex items-start gap-2.5 text-sm text-on-light">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 10.5 8 14l8-8.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                {it}
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </Section>

  <!-- GALERÍA DEL SOFTWARE -->
  {d.galeria && d.galeria.length > 0 && (
    <Section theme="light" id="galeria">
      <div class="mx-auto max-w-3xl text-center">
        <Eyebrow on="light">El producto</Eyebrow>
        <h2 data-reveal class="text-balance text-h1 font-semibold text-on-light">
          {d.galeriaTitulo ?? 'El software en operación'}
        </h2>
        {d.galeriaIntro && (
          <p data-reveal class="mt-5 text-lg leading-relaxed text-muted">{d.galeriaIntro}</p>
        )}
      </div>

      <div class="mt-16 grid gap-6 md:grid-cols-2">
        {d.galeria.map((img, i) => (
          <figure
            data-reveal
            class={`card group flex flex-col overflow-hidden rounded-2xl border border-ink/10 bg-surface shadow-sm ring-1 ring-ink/5 hover:[translate:0_-6px] hover:border-brand/30 hover:shadow-lg ${i === 0 ? 'md:col-span-2' : ''}`}
            style={`--reveal-delay:${i * 80}ms`}
          >
            {img.src && !img.pending ? (
              <div class="overflow-hidden bg-ink/5">
                <img
                  src={img.src}
                  alt={img.alt}
                  loading="lazy"
                  class="h-auto w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
                />
              </div>
            ) : (
              <!-- Mockup: marcador de posición con forma de interfaz -->
              <div class="mock relative flex aspect-video w-full flex-col overflow-hidden bg-light" role="img" aria-label={`Mockup pendiente: ${img.alt}`}>
                <!-- Barra de ventana -->
                <div class="flex items-center gap-1.5 border-b border-ink/10 bg-white px-4 py-3">
                  <span class="h-2.5 w-2.5 rounded-full bg-ink/15"></span>
                  <span class="h-2.5 w-2.5 rounded-full bg-ink/15"></span>
                  <span class="h-2.5 w-2.5 rounded-full bg-ink/15"></span>
                  <span class="ml-3 h-3 w-32 rounded-full bg-ink/10 sm:w-48"></span>
                  <span class="ml-auto h-5 w-5 rounded bg-ink/10"></span>
                </div>
                <!-- Cuerpo: sidebar + KPIs + gráfico -->
                <div class="flex min-h-0 flex-1 gap-3 p-3 sm:gap-4 sm:p-4">
                  <div class="hidden w-1/5 shrink-0 flex-col gap-2 sm:flex">
                    <span class="h-7 rounded-lg bg-brand/20"></span>
                    <span class="h-5 rounded-lg bg-ink/10"></span>
                    <span class="h-5 rounded-lg bg-ink/10"></span>
                    <span class="h-5 rounded-lg bg-ink/10"></span>
                    <span class="h-5 rounded-lg bg-ink/10"></span>
                  </div>
                  <div class="flex min-h-0 flex-1 flex-col gap-3">
                    <div class="grid grid-cols-3 gap-3">
                      <span class="h-12 rounded-xl bg-white ring-1 ring-ink/10 sm:h-14"></span>
                      <span class="h-12 rounded-xl bg-white ring-1 ring-ink/10 sm:h-14"></span>
                      <span class="h-12 rounded-xl bg-white ring-1 ring-ink/10 sm:h-14"></span>
                    </div>
                    <div class="flex min-h-0 flex-1 items-end gap-1.5 rounded-xl bg-white p-3 ring-1 ring-ink/10 sm:gap-2">
                      {[42, 68, 50, 84, 60, 92, 56].map((h) => (
                        <span class="flex-1 rounded-t bg-brand/25" style={`height:${h}%`}></span>
                      ))}
                    </div>
                  </div>
                </div>
                <!-- Etiqueta -->
                <div class="pointer-events-none absolute bottom-3 right-3 inline-flex items-center gap-1.5 rounded-full border border-ink/10 bg-white/90 px-3 py-1 text-xs font-medium text-muted backdrop-blur">
                  <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5Zm0 12 5-5 4 4 3-3 6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><circle cx="8.5" cy="8.5" r="1.5" fill="currentColor"/></svg>
                  Captura próximamente
                </div>
              </div>
            )}
            {img.caption && (
              <figcaption class="border-t border-ink/5 px-5 py-4 text-sm font-medium text-on-light">{img.caption}</figcaption>
            )}
          </figure>
        ))}
      </div>
    </Section>
  )}

  <!-- SOLUCIONES POR SECTOR -->
  {aplicaciones.length > 0 && (
    <Section theme="light" id="por-sector">
      <div class="mx-auto max-w-3xl text-center">
        <Eyebrow on="light">Soluciones por sector</Eyebrow>
        <h2 data-reveal class="text-balance text-h1 font-semibold text-on-light">
          {producto.nombre} en su industria.
        </h2>
        <p data-reveal class="mt-5 text-lg leading-relaxed text-muted">
          Las mismas capacidades, aterrizadas en los casos de uso reales de cada
          sector. Diseñamos la solución a la medida de su operación.
        </p>
      </div>

      <div class="mt-16 grid gap-6 md:grid-cols-2">
        {aplicaciones.map((a, i) => (
          <article
            data-reveal
            class="card relative flex flex-col overflow-hidden rounded-2xl border border-ink/10 bg-surface p-8 shadow-sm ring-1 ring-ink/5 hover:[translate:0_-6px] hover:shadow-lg"
            style={`--reveal-delay:${i * 80}ms; --sector:${a.info!.color}`}
          >
            <span class="absolute inset-x-0 top-0 h-1" style="background:var(--sector)" aria-hidden="true"></span>
            <div class="flex items-center gap-2.5">
              <span class="inline-block h-2.5 w-2.5 rounded-full" style="background:var(--sector)" aria-hidden="true"></span>
              <h3 class="text-xl font-semibold text-on-light">{a.info!.nombre}</h3>
            </div>
            <p class="mt-3 text-sm leading-relaxed text-muted">{a.resumen}</p>
            <ul class="mt-5 grid gap-2.5 border-t border-ink/5 pt-5">
              {a.casos.map((caso) => (
                <li class="flex items-start gap-2.5 text-sm text-on-light">
                  <svg class="mt-0.5 h-4 w-4 shrink-0" style="color:var(--sector)" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 10.5 8 14l8-8.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  {caso}
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>

      <p data-reveal class="mt-10 text-center text-sm text-muted">
        ¿Su sector no está en la lista? <a href="/#contacto" class="font-semibold text-brand hover:underline">Cuéntenos su caso</a> y entrenamos un modelo a su medida.
      </p>
    </Section>
  )}

  <!-- CÓMO FUNCIONA -->
  <Section theme="dark" id="como-funciona" grid={true}>
    <div class="mx-auto max-w-3xl text-center">
      <Eyebrow on="dark">Cómo funciona</Eyebrow>
      <h2 data-reveal class="text-balance text-h1 font-semibold text-on-dark">De la captura a la decisión.</h2>
    </div>

    <ol class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {d.comoFunciona.map((paso, i) => (
        <li
          data-reveal
          class="card group relative flex flex-col rounded-2xl border border-white/10 bg-ink-card p-7 ring-1 ring-white/5 hover:[translate:0_-4px] hover:border-brand/40 hover:shadow-xl hover:shadow-brand/10"
          style={`--reveal-delay:${i * 80}ms`}
        >
          <span
            aria-hidden="true"
            data-count={String(i + 1)}
            data-pad="2"
            class="inline-block origin-top-left text-6xl font-bold leading-none tracking-tight text-white/10 transition-all duration-300 group-hover:scale-110 group-hover:text-brand-400"
          >{String(i + 1).padStart(2, '0')}</span>
          <h3 class="mt-4 text-lg font-semibold text-on-dark">{paso.titulo}</h3>
          <p class="mt-2 text-sm leading-relaxed text-muted-dark">{paso.texto}</p>
        </li>
      ))}
    </ol>
  </Section>

  <!-- BENEFICIOS -->
  <Section theme="light" id="beneficios">
    <div class="mx-auto max-w-3xl text-center">
      <Eyebrow on="light">Por qué {producto.nombre}</Eyebrow>
      <h2 data-reveal class="text-balance text-h1 font-semibold text-on-light">Lo que gana su operación.</h2>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {d.beneficios.map((b, i) => (
        <div
          data-reveal
          class="card group flex flex-col rounded-2xl border border-ink/10 bg-surface p-7 shadow-sm ring-1 ring-ink/5 hover:[translate:0_-4px] hover:border-brand/40 hover:shadow-lg"
          style={`--reveal-delay:${i * 80}ms`}
        >
          <span
            aria-hidden="true"
            data-count={String(i + 1)}
            data-pad="2"
            class="inline-block origin-top-left text-6xl font-bold leading-none tracking-tight text-ink/10 transition-all duration-300 group-hover:scale-110 group-hover:text-brand"
          >{String(i + 1).padStart(2, '0')}</span>
          <h3 class="mt-4 text-base font-semibold text-on-light">{b.titulo}</h3>
          <p class="mt-2 text-sm leading-relaxed text-muted">{b.texto}</p>
        </div>
      ))}
    </div>

    {aplicaciones.length === 0 && relacionados.length > 0 && (
      <div class="mt-14 border-t border-ink/10 pt-10 text-center">
        <p class="text-sm font-medium text-muted">Donde más aplica</p>
        <div class="mt-4 flex flex-wrap justify-center gap-2.5">
          {relacionados.map((s) => (
            <a href="/#sectores" class="rounded-full border border-ink/15 bg-ink/5 px-4 py-1.5 text-sm font-medium text-on-light transition-colors hover:border-brand/40 hover:text-brand">
              {s!.nombre}
            </a>
          ))}
        </div>
      </div>
    )}
  </Section>

  <!-- CIERRE: stack integral (cross-sell) + CTA -->
  <section class="relative isolate overflow-hidden bg-ink py-24 text-on-dark">
    <div class="tech-grid pointer-events-none absolute inset-0 opacity-40" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-6xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <Eyebrow on="dark">Un solo aliado</Eyebrow>
        <h2 class="text-balance text-h1 font-semibold text-on-dark">
          {producto.nombre} es parte del stack integral de AdariA.
        </h2>
        <p class="mt-5 text-lg leading-relaxed text-muted-dark">
          Del sensor a la decisión: combínalo con el resto del stack para cubrir
          toda la cadena —a la medida y con dato auditable— bajo un mismo techo.
        </p>
      </div>

      <div class="mt-12 grid gap-5 sm:grid-cols-2">
        {otros.map((o) => (
          <a
            href={`/productos/${o.slug}`}
            class="group flex items-start gap-4 rounded-2xl border border-white/10 bg-ink-card p-6 ring-1 ring-white/5 transition-all hover:-translate-y-1 hover:border-brand/40"
          >
            <span class="inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-brand/15 text-brand-400 transition-colors group-hover:bg-brand group-hover:text-white">
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d={o.icon} stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
            <div>
              <p class="text-xs font-medium text-brand-400">{o.categoria}</p>
              <h3 class="text-lg font-semibold text-on-dark">{o.nombre}</h3>
              <p class="mt-1 text-sm leading-relaxed text-muted-dark">{o.tagline}</p>
              <span class="mt-3 inline-flex items-center gap-1.5 text-sm font-semibold text-brand-400 transition-all group-hover:gap-2.5">
                Ver producto
                <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 10h12m0 0-5-5m5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-14 rounded-3xl border border-white/10 bg-ink-card p-10 text-center ring-1 ring-white/5 sm:p-12">
        <h2 class="text-h2 font-semibold text-on-dark">¿Lo llevamos a su operación?</h2>
        <p class="mx-auto mt-3 max-w-xl text-muted-dark">
          Cuéntenos su reto y diseñamos un piloto de {producto.nombre} a la medida de su industria.
        </p>
        <div class="mt-7 flex justify-center">
          <Button href="/#contacto" variant="primary" on="dark">Hable con un experto</Button>
        </div>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
</BaseLayout>

<style>
  .js [data-reveal].card {
    opacity: 0;
    transform: translateY(22px);
    transition:
      opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1) var(--reveal-delay, 0ms),
      transform 0.7s cubic-bezier(0.16, 1, 0.3, 1) var(--reveal-delay, 0ms),
      translate 0.35s ease,
      box-shadow 0.35s ease,
      border-color 0.35s ease;
  }
  .js [data-reveal].card.is-visible {
    opacity: 1;
    transform: none;
  }

  /* Mockup: brillo sutil que recorre el placeholder (se detiene con reduce-motion). */
  @media (prefers-reduced-motion: no-preference) {
    .mock::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(
        110deg,
        transparent 35%,
        rgba(255, 255, 255, 0.5) 50%,
        transparent 65%
      );
      transform: translateX(-100%);
      animation: mock-shimmer 2.6s ease-in-out infinite;
      pointer-events: none;
    }
  }
  @keyframes mock-shimmer {
    to {
      transform: translateX(100%);
    }
  }
</style>
