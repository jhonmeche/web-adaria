---
// §9.1 — Hero: carrusel a pantalla completa. La IMAGEN de cada solución ocupa
// todo el ancho (full-bleed) y el TÍTULO va ENCIMA, con degradado + sombra para
// legibilidad. Título e imagen rotan sincronizados.
import Button from '../ui/Button.astro';

// ── SOLUCIONES DEL CARRUSEL ────────────────────────────────────────────────
// Imágenes en  public/hero/  (slide-1.png ... slide-5.png). Si una falta, se
// oculta sola y el título igual rota. Titulares cortos y paralelos (impacto).
const slides = [
  {
    titulo: 'Visión artificial que optimiza la producción.',
    img: '/hero/slide-1.png',
    alt: 'Sistema de visión artificial inspeccionando una línea de producción',
  },
  {
    titulo: 'Hardware a la medida, integrado a la solución de software.',
    img: '/hero/slide-4.webp',
    alt: 'Diseño de hardware electrónico a la medida integrado con la plataforma de software',
  },
  {
    titulo: 'Mantenimiento predictivo que se anticipa a las fallas.',
    img: '/hero/slide-3.png',
    alt: 'Plataforma centralizada de monitoreo en tiempo real y mantenimiento predictivo de equipos industriales',
  },
  {
    titulo: 'Trazabilidad y datos auditables de extremo a extremo.',
    img: '/hero/slide-4.png',
    alt: 'Dashboard de trazabilidad y datos auditables',
  },
  {
    titulo: 'Seguridad laboral y EPP verificados con visión artificial.',
    img: '/hero/slide-2.png',
    alt: 'Detección automática de EPP y seguridad laboral con visión artificial',
  },
];
---

<section
  data-rotator
  class="relative isolate flex min-h-[90svh] items-center overflow-hidden bg-ink text-on-dark"
  aria-roledescription="carrusel"
  aria-label="Soluciones de AdariA Systems"
>
  <!-- Imágenes full-bleed apiladas -->
  <div class="absolute inset-0 -z-20" aria-hidden="true">
    <!-- placeholder de respaldo -->
    <div class="absolute inset-0 bg-ink">
      <div class="tech-grid absolute inset-0 opacity-50"></div>
    </div>
    {slides.map((s, i) => (
      <div class:list={['rot-img absolute inset-0', { 'is-active': i === 0 }]}>
        <img
          src={s.img}
          alt={s.alt}
          class="h-full w-full object-cover object-center"
          loading={i === 0 ? 'eager' : 'lazy'}
          fetchpriority={i === 0 ? 'high' : 'auto'}
          decoding="async"
          onerror="this.style.visibility='hidden'"
        />
      </div>
    ))}
  </div>

  <!-- Degradado de legibilidad (desktop): oscuro a la izquierda, se aclara a la derecha -->
  <div class="absolute inset-0 -z-10 hidden bg-linear-to-r from-ink from-0% via-ink/60 via-45% to-ink/10 to-90% md:block" aria-hidden="true"></div>
  <!-- Refuerzo inferior (desktop): asienta CTA, features e indicador de scroll -->
  <div class="absolute inset-x-0 bottom-0 -z-10 hidden h-1/3 bg-linear-to-t from-ink/70 to-transparent md:block" aria-hidden="true"></div>
  <!-- En móvil, velo vertical (la imagen va detrás del texto centrado) -->
  <div class="absolute inset-0 -z-10 bg-linear-to-t from-ink via-ink/70 to-ink/40 md:hidden" aria-hidden="true"></div>

  <!-- Contenido encima de la imagen -->
  <div class="relative mx-auto w-full max-w-6xl px-6 py-28 lg:px-8">
    <div class="max-w-2xl">
      <!-- Eyebrow: ancla estable mientras el titular rota -->
      <p class="mb-5 inline-flex items-center gap-2.5 text-sm font-semibold tracking-tight text-brand-400">
        <span class="h-px w-8 bg-current opacity-70"></span>
        Soluciones tecnológicas a la medida
      </p>

      <h1 class="rot-stage grid text-balance text-display font-semibold [text-shadow:0_2px_24px_rgba(0,0,0,0.4)]">
        {slides.map((s, i) => (
          <span class:list={['rot-slide', { 'is-active': i === 0 }]} aria-hidden={i !== 0}>{s.titulo}</span>
        ))}
      </h1>

      <!-- Puntos indicadores -->
      <div class="rot-dots mt-7 flex gap-2.5" role="tablist" aria-label="Soluciones de AdariA Systems">
        {slides.map((s, i) => (
          <button
            type="button"
            class:list={['rot-dot', { 'is-active': i === 0 }]}
            data-i={i}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-label={s.titulo}
          ></button>
        ))}
      </div>

      <p data-reveal class="mt-8 max-w-xl text-balance text-lg leading-relaxed text-white [text-shadow:0_1px_12px_rgba(0,0,0,0.45)] sm:text-xl">
        Llevamos la Industria 4.0 a la operación real. Integramos visión
        artificial, IoT e infraestructura propia para convertir cada dato en una
        decisión —y cada decisión, en operaciones más seguras, eficientes y
        auditables.
      </p>

      <div data-reveal class="mt-10 flex flex-col gap-3 sm:flex-row sm:items-center">
        <Button href="#contacto" variant="primary" on="dark">Habla con un experto</Button>
        <Button href="#solucion" variant="secondary" on="dark">Cómo funciona</Button>
      </div>

      <ul data-reveal class="mt-12 flex flex-wrap gap-x-6 gap-y-3 text-sm text-muted-dark">
        {[
          ['Visión', 'artificial'],
          ['IoT', 'LoRa/LoRaWAN'],
          ['Hardware', 'propio'],
          ['Dato', 'auditable'],
        ].map(([t, s]) => (
          <li class="flex items-center gap-2">
            <span class="h-1.5 w-1.5 rounded-full bg-brand-400"></span>
            <span><span class="font-semibold text-on-dark">{t}</span> {s}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Indicador de scroll -->
  <a
    href="#problema"
    class="absolute inset-x-0 bottom-6 z-10 mx-auto hidden w-fit flex-col items-center gap-1 text-muted-dark transition-colors hover:text-on-dark md:flex"
    aria-label="Desplazarse a la siguiente sección"
  >
    <span class="text-xs font-medium">Descubre cómo</span>
    <svg class="scroll-cue h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </a>
</section>

<style>
  /* Títulos apilados (misma celda → sin saltos de altura) */
  .rot-stage > .rot-slide { grid-area: 1 / 1; }
  .rot-slide {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 1s ease, transform 1s ease;
    pointer-events: none;
  }
  .rot-slide.is-active { opacity: 1; transform: none; }

  /* Imágenes full-bleed apiladas */
  .rot-img {
    opacity: 0;
    transition: opacity 1.1s ease;
  }
  .rot-img.is-active { opacity: 1; }

  /* Puntos */
  .rot-dot {
    height: 0.5rem;
    width: 1.25rem;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.25);
    transition: background 0.3s ease, width 0.3s ease;
    cursor: pointer;
  }
  .rot-dot:hover { background: rgba(255, 255, 255, 0.45); }
  .rot-dot:focus-visible { outline: 2px solid var(--color-brand-400); outline-offset: 3px; }
  .rot-dot.is-active { width: 2.25rem; background: var(--color-brand-400); }

  /* Indicador de scroll: rebote sutil */
  @media (prefers-reduced-motion: no-preference) {
    .scroll-cue { animation: scroll-cue 1.8s ease-in-out infinite; }
  }
  @keyframes scroll-cue {
    0%, 100% { transform: translateY(0); opacity: 0.7; }
    50% { transform: translateY(5px); opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .rot-slide, .rot-img { transition: opacity 0.3s ease; transform: none; }
  }
</style>

<script>
  const root = document.querySelector('[data-rotator]');
  if (root) {
    const titles = Array.from(root.querySelectorAll('.rot-slide'));
    const imgs = Array.from(root.querySelectorAll('.rot-img'));
    const dots = Array.from(root.querySelectorAll('.rot-dot'));
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let i = 0;
    let timer: number | undefined;

    const setActive = (els: Element[], n: number, on: boolean) => {
      const el = els[n];
      if (!el) return;
      el.classList.toggle('is-active', on);
      el.setAttribute('aria-hidden', on ? 'false' : 'true');
    };

    const show = (n: number) => {
      setActive(titles, i, false);
      setActive(imgs, i, false);
      dots[i]?.classList.remove('is-active');
      dots[i]?.setAttribute('aria-selected', 'false');

      i = (n + titles.length) % titles.length;

      setActive(titles, i, true);
      setActive(imgs, i, true);
      dots[i]?.classList.add('is-active');
      dots[i]?.setAttribute('aria-selected', 'true');
    };
    const next = () => show(i + 1);
    const play = () => { if (reduce) return; stop(); timer = window.setInterval(next, 6500); };
    const stop = () => { if (timer) window.clearInterval(timer); };

    dots.forEach((d, n) => d.addEventListener('click', () => { show(n); play(); }));
    // Pausa con mouse y con foco de teclado (accesibilidad WCAG 2.2.2)
    root.addEventListener('mouseenter', stop);
    root.addEventListener('mouseleave', play);
    root.addEventListener('focusin', stop);
    root.addEventListener('focusout', play);
    play();
  }
</script>
