---
// §9.5 — Sectores: tarjetas por industria. Fondo BLANCO (alterna oscuro→
// blanco desde el Hero); las tarjetas se mantienen oscuras a propósito para
// que destaquen sobre el fondo claro (mismo recurso que el placeholder de
// Smart PBA).
// En la HOME solo manda el azul de marca (Opción C); el color sectorial se
// reserva para cada landing. Las imágenes son placeholders marcados para
// reemplazar por fotos reales de operación.
import Section from '../ui/Section.astro';
import Eyebrow from '../ui/Eyebrow.astro';
import { sectores } from '../../data/sectores.ts';
---

<Section theme="white" id="sectores">
  <div class="mx-auto max-w-3xl text-center">
    <Eyebrow on="light">Soluciones por sector</Eyebrow>
    <h2 data-reveal class="text-h1 font-semibold text-on-light">
      Ingeniería de extremo a extremo<br class="hidden sm:block" /> para su industria.
    </h2>
    <p data-reveal class="mt-5 text-lg leading-relaxed text-muted">
      Diseñamos hardware electrónico propio —nodos, gateways y dispositivos
      edge—, sensorizamos con IoT y conectividad LoRa/LoRaWAN y entrenamos
      modelos de visión artificial. Procesamos en el borde,
      integramos con ERP, PLCs, básculas y SCADA, y entregamos analítica
      predictiva con dato trazable y auditable.
    </p>
  </div>

  <div class="mt-16 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
    {sectores.map((s, i) => (
      <a
        href="#sectores"
        data-reveal
        class="sector-card group relative flex flex-col overflow-hidden rounded-2xl border border-white/10 bg-ink-card-soft hover:[translate:0_-6px] hover:border-brand/40"
        style={`--reveal-delay:${i * 90}ms`}
      >
        <!-- Media de la tarjeta: video (fondo en bucle) · imagen · o placeholder -->
        <div class="relative aspect-3/2 overflow-hidden bg-linear-to-br from-ink-card-soft to-ink-card">
          {s.video ? (
            <video
              class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
              src={s.video}
              poster={s.imagen}
              autoplay
              muted
              loop
              playsinline
              webkit-playsinline
              preload="metadata"
              aria-hidden="true"
              data-sector-video
            ></video>
          ) : s.imagen ? (
            <img
              src={s.imagen}
              alt={s.nombre}
              class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
              decoding="async"
            />
          ) : (
            <>
              <div class="tech-grid absolute inset-0 opacity-40" aria-hidden="true"></div>
              <div class="absolute inset-0 flex items-center justify-center">
                <svg class="h-10 w-10 text-white/15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={s.icon} />
                </svg>
              </div>
            </>
          )}
          {(s.video || s.imagen) && (
            <div class="pointer-events-none absolute inset-0 bg-linear-to-t from-ink/60 via-transparent to-transparent" aria-hidden="true"></div>
          )}
          {s.prioritario && (
            <span class="absolute left-4 top-4 z-10 rounded-full bg-brand px-3 py-1 text-xs font-semibold text-white">
              Sector prioritario
            </span>
          )}
        </div>
        <div class="flex flex-1 flex-col p-6">
          <h3 class="text-lg font-semibold text-on-dark">{s.nombre}</h3>
          <p class="mt-2 text-sm leading-relaxed text-muted-dark">{s.gancho}</p>
          <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-brand-400 transition-all group-hover:gap-2.5">
            Ver solución
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 10h12m0 0-5-5m5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </div>
      </a>
    ))}

    <!-- 6ª tarjeta: invitación (completa la rejilla 2×3 y capta industrias no listadas) -->
    <a
      href="#contacto"
      data-reveal
      class="sector-card group relative flex flex-col items-center justify-center overflow-hidden rounded-2xl border border-dashed border-white/20 bg-ink-card-soft/70 p-8 text-center hover:[translate:0_-6px] hover:border-brand/50"
      style={`--reveal-delay:${sectores.length * 90}ms`}
    >
      <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-brand/15 text-brand-400 transition-colors group-hover:bg-brand group-hover:text-white">
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </span>
      <h3 class="mt-5 text-lg font-semibold text-on-dark">¿Tu industria no está aquí?</h3>
      <p class="mt-2 text-sm leading-relaxed text-muted-dark">
        Diseñamos soluciones a la medida para cualquier operación. Cuéntanos tu reto.
      </p>
      <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-brand-400 transition-all group-hover:gap-2.5">
        Hablemos
        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 10h12m0 0-5-5m5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </span>
    </a>
  </div>
</Section>

<style>
  /* Entrada escalonada de las tarjetas: fade + slide-up + leve zoom, con retardo
     por tarjeta (--reveal-delay). El reveal usa `transform`; el hover usa la
     propiedad `translate` (independiente) para no pisarse. */
  .js [data-reveal].sector-card {
    opacity: 0;
    transform: translateY(26px) scale(0.97);
    transition:
      opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1) var(--reveal-delay, 0ms),
      transform 0.7s cubic-bezier(0.16, 1, 0.3, 1) var(--reveal-delay, 0ms),
      translate 0.35s ease,
      border-color 0.35s ease;
  }
  .js [data-reveal].sector-card.is-visible {
    opacity: 1;
    transform: none;
  }
</style>

<script>
  // Reproducción de los videos de fondo de las tarjetas. En móvil, el autoplay
  // del HTML suele estar bloqueado (ahorro de datos / bajo consumo), así que lo
  // forzamos por JS cuando la tarjeta entra en pantalla, y lo pausamos al salir
  // (carga diferida → mejor rendimiento). Respeta prefers-reduced-motion.
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const videos = Array.from(
    document.querySelectorAll<HTMLVideoElement>('video[data-sector-video]'),
  );

  if (videos.length && !reduce) {
    const tryPlay = (v: HTMLVideoElement) => {
      v.muted = true;
      const p = v.play();
      if (p && typeof p.catch === 'function') p.catch(() => {});
    };

    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            const v = e.target as HTMLVideoElement;
            if (e.isIntersecting) tryPlay(v);
            else v.pause();
          });
        },
        { threshold: 0.25 },
      );
      videos.forEach((v) => io.observe(v));
    } else {
      videos.forEach(tryPlay);
    }

    // Fallback: algunos navegadores solo permiten reproducir tras la 1ª
    // interacción del usuario. Al primer toque/scroll, reintenta los visibles.
    const kick = () => {
      videos.forEach((v) => {
        const r = v.getBoundingClientRect();
        if (r.top < window.innerHeight && r.bottom > 0) tryPlay(v);
      });
    };
    window.addEventListener('touchstart', kick, { once: true, passive: true });
    window.addEventListener('scroll', kick, { once: true, passive: true });
  }
</script>
