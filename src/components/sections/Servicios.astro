---
// §4 / §7 — Servicios (capacidades núcleo). Cierra el ancla #servicios que la
// nav enlazaba sin destino. Presenta a AdariA como un equipo de ingeniería
// integral (las 6 capacidades, fondo BLANCO) y luego su metodología de trabajo
// (fondo OSCURO), para seguir la alternancia oscuro→blanco desde el Hero:
// Stack (oscuro) → Servicios/capacidades (blanco) → Servicios/método (oscuro)
// → Sectores (blanco). Reutiliza el patrón visual del sitio (cards data-reveal,
// íconos de trazo, números grandes en hover).
import Section from '../ui/Section.astro';
import Eyebrow from '../ui/Eyebrow.astro';
import Button from '../ui/Button.astro';
import { servicios } from '../../data/servicios.ts';

// Las 6 capacidades núcleo del brief (§4) viven en data/servicios.ts y
// alimentan también su landing dedicada (/servicios/[slug]). Aquí solo
// presentamos la card con su ícono de trazo, tags y enlace a "Saber más".

// Metodología — el "gráfico profesional" de proceso: cómo trabaja el equipo,
// de la conversación inicial al soporte continuo.
const metodologia = [
  { titulo: 'Descubrimiento', texto: 'Entendemos su operación, el dolor real y el caso de uso prioritario.' },
  { titulo: 'Diseño', texto: 'Definimos arquitectura, hardware y modelos a la medida del problema.' },
  { titulo: 'Piloto', texto: 'Validamos en campo con un alcance acotado, medible y de bajo costo.' },
  { titulo: 'Despliegue', texto: 'Escalamos a producción e integramos con sus sistemas existentes.' },
  { titulo: 'Soporte', texto: 'Operación monitoreada, mejora continua y mantenimiento.' },
];
---

<Section theme="white" id="servicios" aria-labelledby="servicios-title">
  <div class="mx-auto flex max-w-3xl flex-col items-center text-center">
    <Eyebrow on="light">Servicios</Eyebrow>
    <h2 id="servicios-title" data-reveal class="text-balance text-h1 font-semibold text-on-light">
      Un equipo de ingeniería integral,<br class="hidden sm:block" /> bajo un mismo techo.
    </h2>
    <p data-reveal class="mt-6 max-w-2xl text-balance text-lg leading-relaxed text-muted">
      Diseñamos el hardware, capturamos el dato, entrenamos los modelos, lo
      integramos y lo devolvemos convertido en decisiones. Seis capacidades que
      cubren la cadena completa —del sensor a la decisión— con desarrollo a la medida.
    </p>
  </div>

  <!-- Capacidades -->
  <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {servicios.map((c, i) => (
      <article
        data-reveal
        class="card group relative flex flex-col rounded-2xl border border-ink/10 bg-light p-8 ring-1 ring-ink/5 hover:[translate:0_-6px] hover:border-brand/40 hover:shadow-lg"
        style={`--reveal-delay:${i * 70}ms`}
      >
        <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-brand/10 text-brand transition-colors group-hover:bg-brand group-hover:text-white">
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d={c.icon} stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </span>
        <h3 class="mt-5 text-xl font-semibold text-on-light">{c.nombre}</h3>
        <p class="mt-2 text-sm leading-relaxed text-muted">{c.resumen}</p>
        <ul class="mt-5 flex flex-wrap gap-2 border-t border-ink/10 pt-5">
          {c.tags.map((t) => (
            <li class="rounded-full border border-ink/10 bg-surface px-3 py-1 text-xs font-medium text-on-light/75">{t}</li>
          ))}
        </ul>
        <a
          href={`/servicios/${c.slug}`}
          class="mt-auto inline-flex items-center gap-1.5 pt-6 text-sm font-semibold text-brand transition-all group-hover:gap-2.5"
        >
          Saber más
          <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 10h12m0 0-5-5m5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </article>
    ))}
  </div>
</Section>

<Section theme="dark" id="metodologia" grid={true} aria-labelledby="metodologia-title">
  <!-- Metodología: cómo trabaja el equipo (gráfico de proceso) -->
  <div class="mx-auto max-w-3xl text-center">
    <Eyebrow on="dark">Cómo trabajamos</Eyebrow>
    <h3 id="metodologia-title" data-reveal class="text-balance text-h2 font-semibold text-on-dark">
      Un método de equipo profesional, no improvisación.
    </h3>
    <p data-reveal class="mt-5 text-lg leading-relaxed text-muted-dark">
      Empezamos pequeño y de bajo riesgo, validamos con datos y escalamos. Land
      &amp; expand: del piloto a la operación gestionada.
    </p>
  </div>

  <!-- Ruta de trabajo: línea de tiempo horizontal (no otra tarjeta con número
       ghost — ese lenguaje ya lo usa "Del sensor a la decisión"). El riel
       conecta los cinco hitos como un recorrido; el pulso viaja de
       Descubrimiento a Soporte. -->
  <div class="relative mt-16">
    <div
      aria-hidden="true"
      class="absolute inset-x-[6%] top-3.25 hidden h-px overflow-hidden bg-white/10 lg:block"
    >
      <span class="flow-dot absolute inset-y-0 left-0 w-20 bg-linear-to-r from-transparent via-brand-400 to-transparent"></span>
    </div>

    <ol class="grid gap-8 sm:grid-cols-2 lg:grid-cols-5 lg:gap-6">
      {metodologia.map((p, i) => (
        <li
          data-reveal
          class="hito relative pl-9 lg:pl-0 lg:text-center"
          style={`--reveal-delay:${i * 80}ms`}
        >
          <span
            aria-hidden="true"
            class="absolute left-0 top-0 flex h-7 w-7 items-center justify-center rounded-full border-2 border-brand-400 bg-ink text-xs font-bold text-brand-400 lg:relative lg:mx-auto lg:mb-4"
          >{i + 1}</span>
          <h4 class="text-base font-semibold text-on-dark">{p.titulo}</h4>
          <p class="mt-1.5 text-sm leading-relaxed text-muted-dark lg:mx-auto lg:max-w-[16rem]">{p.texto}</p>
        </li>
      ))}
    </ol>
  </div>

  <!-- CTA -->
  <div data-reveal class="mt-20 rounded-3xl border border-white/10 bg-ink-card p-10 text-center ring-1 ring-white/5 sm:p-12">
    <h3 class="text-h2 font-semibold text-on-dark">¿Existe un reto técnico por resolver?</h3>
    <p class="mx-auto mt-3 max-w-xl text-muted-dark">
      Cuéntenos su operación y diseñamos la solución a la medida —con hardware,
      software y datos— que de verdad necesitas.
    </p>
    <div class="mt-7 flex flex-col justify-center gap-3 sm:flex-row">
      <Button href="#contacto" variant="primary" on="dark">Hablemos de su proyecto</Button>
      <Button href="#productos" variant="secondary" on="dark">Ver el stack de productos</Button>
    </div>
  </div>
</Section>

<style>
  /* Reveal escalonado (mismo patrón que el resto de secciones). El hover usa la
     propiedad individual `translate`, independiente del `transform` del reveal. */
  .js [data-reveal].card {
    opacity: 0;
    transform: translateY(22px);
    transition:
      opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1) var(--reveal-delay, 0ms),
      transform 0.7s cubic-bezier(0.16, 1, 0.3, 1) var(--reveal-delay, 0ms),
      translate 0.35s ease,
      box-shadow 0.35s ease,
      border-color 0.35s ease;
  }
  .js [data-reveal].card.is-visible {
    opacity: 1;
    transform: none;
  }

  .js [data-reveal].hito {
    opacity: 0;
    transform: translateY(16px);
    transition:
      opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1) var(--reveal-delay, 0ms),
      transform 0.6s cubic-bezier(0.16, 1, 0.3, 1) var(--reveal-delay, 0ms);
  }
  .js [data-reveal].hito.is-visible {
    opacity: 1;
    transform: none;
  }
</style>
