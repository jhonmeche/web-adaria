---
// §4 / §7 — Servicios (capacidades núcleo). Cierra el ancla #servicios que la
// nav enlazaba sin destino. Fondo OSCURO con rejilla técnica: presenta a AdariA
// como un equipo de ingeniería integral (las 6 capacidades) y su metodología de
// trabajo. Reutiliza el patrón visual del sitio (cards data-reveal, íconos de
// trazo, números grandes en hover).
import Section from '../ui/Section.astro';
import Eyebrow from '../ui/Eyebrow.astro';
import Button from '../ui/Button.astro';
import { servicios } from '../../data/servicios.ts';

// Las 6 capacidades núcleo del brief (§4) viven en data/servicios.ts y
// alimentan también su landing dedicada (/servicios/[slug]). Aquí solo
// presentamos la card con su ícono de trazo, tags y enlace a "Saber más".

// Metodología — el "gráfico profesional" de proceso: cómo trabaja el equipo,
// de la conversación inicial al soporte continuo.
const metodologia = [
  { titulo: 'Descubrimiento', texto: 'Entendemos tu operación, el dolor real y el caso de uso prioritario.' },
  { titulo: 'Diseño', texto: 'Definimos arquitectura, hardware y modelos a la medida del problema.' },
  { titulo: 'Piloto', texto: 'Validamos en campo con un alcance acotado, medible y de bajo costo.' },
  { titulo: 'Despliegue', texto: 'Escalamos a producción e integramos con tus sistemas existentes.' },
  { titulo: 'Soporte', texto: 'Operación monitoreada, mejora continua y mantenimiento.' },
];
---

<Section theme="dark" id="servicios" grid={true} aria-labelledby="servicios-title">
  <div class="mx-auto flex max-w-3xl flex-col items-center text-center">
    <Eyebrow on="dark">Servicios</Eyebrow>
    <h2 id="servicios-title" data-reveal class="text-balance text-h1 font-semibold text-on-dark">
      Un equipo de ingeniería integral,<br class="hidden sm:block" /> bajo un mismo techo.
    </h2>
    <p data-reveal class="mt-6 max-w-2xl text-balance text-lg leading-relaxed text-muted-dark">
      Diseñamos el hardware, capturamos el dato, entrenamos los modelos, lo
      integramos y lo devolvemos convertido en decisiones. Seis capacidades que
      cubren la cadena completa —del sensor a la decisión— con desarrollo a la medida.
    </p>
  </div>

  <!-- Capacidades -->
  <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {servicios.map((c, i) => (
      <article
        data-reveal
        class="card group relative flex flex-col rounded-2xl border border-white/10 bg-ink-card p-8 ring-1 ring-white/5 hover:[translate:0_-6px] hover:border-brand/40 hover:shadow-xl hover:shadow-brand/10"
        style={`--reveal-delay:${i * 70}ms`}
      >
        <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-brand/15 text-brand-400 transition-colors group-hover:bg-brand group-hover:text-white">
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d={c.icon} stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </span>
        <h3 class="mt-5 text-xl font-semibold text-on-dark">{c.nombre}</h3>
        <p class="mt-2 text-sm leading-relaxed text-muted-dark">{c.resumen}</p>
        <ul class="mt-5 flex flex-wrap gap-2 border-t border-white/5 pt-5">
          {c.tags.map((t) => (
            <li class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-medium text-on-dark/75">{t}</li>
          ))}
        </ul>
        <a
          href={`/servicios/${c.slug}`}
          class="mt-auto inline-flex items-center gap-1.5 pt-6 text-sm font-semibold text-brand-400 transition-all group-hover:gap-2.5"
        >
          Saber más
          <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 10h12m0 0-5-5m5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </article>
    ))}
  </div>

  <!-- Metodología: cómo trabaja el equipo (gráfico de proceso) -->
  <div class="mt-24">
    <div class="mx-auto max-w-3xl text-center">
      <Eyebrow on="dark">Cómo trabajamos</Eyebrow>
      <h3 data-reveal class="text-balance text-h2 font-semibold text-on-dark">
        Un método de equipo profesional, no improvisación.
      </h3>
      <p data-reveal class="mt-5 text-lg leading-relaxed text-muted-dark">
        Empezamos pequeño y de bajo riesgo, validamos con datos y escalamos. Land
        &amp; expand: del piloto a la operación gestionada.
      </p>
    </div>

    <div class="mt-14">
      <ol class="grid gap-6 sm:grid-cols-2 lg:grid-cols-5">
        {metodologia.map((p, i) => (
          <li
            data-reveal
            class="card group relative flex flex-col rounded-2xl border border-white/10 bg-ink-card p-6 ring-1 ring-white/5 hover:[translate:0_-4px] hover:border-brand/40"
            style={`--reveal-delay:${i * 80}ms`}
          >
            <span
              aria-hidden="true"
              data-count={String(i + 1)}
              data-pad="2"
              class="inline-block origin-top-left text-6xl font-bold leading-none tracking-tight text-white/10 transition-all duration-300 group-hover:scale-110 group-hover:text-brand-400"
            >{String(i + 1).padStart(2, '0')}</span>
            <h4 class="mt-4 text-base font-semibold text-on-dark">{p.titulo}</h4>
            <p class="mt-1.5 text-sm leading-relaxed text-muted-dark">{p.texto}</p>
          </li>
        ))}
      </ol>
    </div>
  </div>

  <!-- CTA -->
  <div data-reveal class="mt-20 rounded-3xl border border-white/10 bg-ink-card p-10 text-center ring-1 ring-white/5 sm:p-12">
    <h3 class="text-h2 font-semibold text-on-dark">¿Tienes un reto técnico en mente?</h3>
    <p class="mx-auto mt-3 max-w-xl text-muted-dark">
      Cuéntanos tu operación y diseñamos la solución a la medida —con hardware,
      software y datos— que de verdad necesitas.
    </p>
    <div class="mt-7 flex flex-col justify-center gap-3 sm:flex-row">
      <Button href="#contacto" variant="primary" on="dark">Hablemos de tu proyecto</Button>
      <Button href="#productos" variant="secondary" on="dark">Ver el stack de productos</Button>
    </div>
  </div>
</Section>

<style>
  /* Reveal escalonado (mismo patrón que el resto de secciones). El hover usa la
     propiedad individual `translate`, independiente del `transform` del reveal. */
  .js [data-reveal].card {
    opacity: 0;
    transform: translateY(22px);
    transition:
      opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1) var(--reveal-delay, 0ms),
      transform 0.7s cubic-bezier(0.16, 1, 0.3, 1) var(--reveal-delay, 0ms),
      translate 0.35s ease,
      box-shadow 0.35s ease,
      border-color 0.35s ease;
  }
  .js [data-reveal].card.is-visible {
    opacity: 1;
    transform: none;
  }
</style>
