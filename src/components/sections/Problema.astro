---
// §9.2 — El problema: el costo de operar a ciegas. Fondo claro.
import Section from '../ui/Section.astro';
import Eyebrow from '../ui/Eyebrow.astro';

const dolores = [
  {
    titulo: 'Fallas que paran la operación',
    texto:
      'El mantenimiento reactivo y las paradas no planeadas cuestan millones. Cuando se reacciona, el daño ya está hecho.',
    icon: 'alert',
  },
  {
    titulo: 'Accidentes y riesgo regulatorio',
    texto:
      'En la industria, cada accidente es altísimo en costo humano y económico, con presión de SST y ambiental.',
    icon: 'shield',
  },
  {
    titulo: 'Procesos manuales y a ciegas',
    texto:
      'Conteos, inspecciones y registros manuales: lentos, costosos y propensos a errores. Sin trazabilidad ni datos confiables, las decisiones se toman a ciegas y los problemas se detectan tarde.',
    icon: 'eye',
  },
];

const icons: Record<string, string> = {
  alert: 'M12 9v4m0 4h.01M10.3 3.9 2.4 18a2 2 0 0 0 1.7 3h15.8a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0Z',
  shield: 'M12 3 5 6v6c0 4 3 7 7 9 4-2 7-5 7-9V6l-7-3Z',
  eye: 'M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Zm10 3a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z',
};
---

<Section theme="light" id="problema" aria-labelledby="problema-title">
  <div class="mx-auto flex max-w-3xl flex-col items-center text-center">
    <Eyebrow on="light">El costo de operar a ciegas</Eyebrow>
    <h2 id="problema-title" data-reveal class="text-balance text-h1 font-semibold text-on-light">
      Lo que no se mide, se paga caro.
    </h2>
    <p data-reveal class="mt-6 max-w-xl text-balance text-lg leading-relaxed text-muted">
      En la industria, la falta de datos a tiempo se traduce en paradas, riesgos
      y sobrecostos. El problema no es la tecnología: es operar sin ver.
    </p>
  </div>

  <div class="mt-16 grid items-stretch gap-6 md:grid-cols-3">
    {dolores.map((d, i) => (
      <div
        data-reveal
        class="card group flex flex-col rounded-2xl border border-ink/10 bg-surface p-8 shadow-sm ring-1 ring-ink/5 hover:[translate:0_-6px] hover:border-ink/25 hover:shadow-lg"
        style={`--reveal-delay:${i * 90}ms`}
      >
        <div class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-brand text-white shadow-lg shadow-brand/30">
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d={icons[d.icon]} stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>
        <h3 class="mb-2 text-lg font-semibold text-on-light">{d.titulo}</h3>
        <p class="text-sm leading-relaxed text-muted">{d.texto}</p>
      </div>
    ))}
  </div>
</Section>

<style>
  /* Entrada escalonada por card: fade + slide-up con --reveal-delay; el hover usa
     la propiedad individual `translate` para no pisar la animación de entrada.
     (Mismo patrón que la sección Stack.) */
  .js [data-reveal].card {
    opacity: 0;
    transform: translateY(22px);
    transition:
      opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1) var(--reveal-delay, 0ms),
      transform 0.7s cubic-bezier(0.16, 1, 0.3, 1) var(--reveal-delay, 0ms),
      translate 0.35s ease,
      box-shadow 0.35s ease,
      border-color 0.35s ease;
  }
  .js [data-reveal].card.is-visible {
    opacity: 1;
    transform: none;
  }
</style>
