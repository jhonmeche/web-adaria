---
// §9.6 — Caso destacado: Smart PBA. Prueba de credibilidad. Fondo claro.
import Section from '../ui/Section.astro';
import Eyebrow from '../ui/Eyebrow.astro';

// Métricas placeholder — reemplazar por cifras reales del caso.
// `count`/`suffix` activan la animación de conteo (los textuales no la usan).
const metricas = [
  { valor: '100%', count: 100, suffix: '%', label: 'de los lotes trazados, del ingreso al despacho' },
  { valor: 'Conteo', label: 'automático de animales por visión artificial' },
  { valor: 'Evidencia', label: 'fotográfica que respalda cada informe' },
];
---

<Section theme="light" id="caso">
  <div class="grid items-center gap-12 lg:grid-cols-2">
    <div>
      <Eyebrow on="light">Caso destacado · Smart PBA</Eyebrow>
      <h2 data-reveal class="text-h2 font-semibold text-on-light">
        Trazabilidad real en plantas de beneficio animal.
      </h2>
      <p data-reveal class="mt-5 text-lg leading-relaxed text-muted">
        Smart PBA es nuestro producto más maduro y nuestra mejor prueba: un ERP
        que gestiona la operación cárnica completa, con conteo por visión
        artificial y evidencia fotográfica que da transparencia total al cliente.
      </p>

      <dl data-reveal class="mt-10 space-y-6">
        {metricas.map((m) => (
          <div class="flex items-baseline gap-4 border-l-2 border-brand pl-4">
            <dt class="text-2xl font-semibold text-brand">
              {m.count != null ? (
                <span data-count={String(m.count)} data-suffix={m.suffix}>{m.valor}</span>
              ) : (
                m.valor
              )}
            </dt>
            <dd class="text-sm text-muted">{m.label}</dd>
          </div>
        ))}
      </dl>

      <a href="#contacto" data-reveal class="mt-10 inline-flex items-center gap-1.5 text-sm font-semibold text-brand hover:gap-2.5">
        Ver cómo Smart PBA puede ayudarte
        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 10h12m0 0-5-5m5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>

    <!-- Placeholder visual: reemplazar por foto de Smart PBA en operación -->
    <div data-reveal class="relative aspect-[4/3] overflow-hidden rounded-2xl border border-ink/5 bg-ink shadow-xl">
      <div class="tech-grid absolute inset-0 opacity-50" aria-hidden="true"></div>
      <div class="absolute inset-0 flex flex-col items-center justify-center gap-3 text-center">
        <svg class="h-12 w-12 text-brand-400" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2v11Z" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="13" r="4" stroke="currentColor" stroke-width="1.5"/></svg>
        <p class="text-sm text-muted-dark">Foto de Smart PBA en planta</p>
      </div>
    </div>
  </div>
</Section>
