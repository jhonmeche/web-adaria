---
// Aliado tecnológico: Granular Electronics (granularelectronics.com), compañía
// hermana —mismos fundadores— especializada en la infraestructura física que
// soporta la operación: redes y cableado (UTP/fibra), WiFi, suministro de
// equipos, energía solar, internet satelital y seguridad electrónica (CCTV,
// alarmas, control de acceso, detección de incendios). Fondo BLANCO, justo
// antes del CTA final (oscuro), para seguir la alternancia oscuro→blanco de
// toda la home.
//
// Tratamiento deliberadamente distinto al resto de tarjetas del sitio: es OTRA
// empresa, no un producto de AdariA. Por eso los íconos de sus capacidades van
// en gris neutro (no en el azul de marca) — el azul se reserva para el único
// CTA que sí es "nuestro": visitar su sitio.
import Section from '../ui/Section.astro';
import Eyebrow from '../ui/Eyebrow.astro';
import Button from '../ui/Button.astro';

// Capacidades de Granular, priorizadas: primero las que complementan de forma
// más directa la infraestructura de AdariA (redes, equipos, incendios), luego
// el resto de su portafolio de seguridad electrónica y energía.
// Cada ícono va como marcado SVG completo (no un solo `path`) porque los
// símbolos claros (red, wifi, cámara, llama, sol...) necesitan varias formas
// combinadas (círculos, líneas, polígonos) para leerse bien a 16px.
const capacidades = [
  {
    label: 'Redes, cableado UTP y fibra',
    svg: '<circle cx="18" cy="5" r="2.8"/><circle cx="6" cy="12" r="2.8"/><circle cx="18" cy="19" r="2.8"/><line x1="8.4" y1="13.3" x2="15.6" y2="17.2"/><line x1="15.6" y1="6.8" x2="8.4" y2="10.7"/>',
  },
  {
    label: 'WiFi e internet satelital',
    svg: '<path d="M5 12.9a11 11 0 0 1 14 0"/><path d="M1.4 9a16 16 0 0 1 21.2 0"/><path d="M8.5 16.7a6 6 0 0 1 7 0"/><circle cx="12" cy="20" r="1" fill="currentColor" stroke="none"/>',
  },
  {
    label: 'Suministro de equipos y soporte IT',
    svg: '<rect x="2.5" y="4" width="19" height="13" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>',
  },
  {
    label: 'Detección de incendios',
    svg: '<path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.07-2.14-.22-4.05 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.15.43-2.29 1-3a2.5 2.5 0 0 0 2.5 2.5Z"/>',
  },
  {
    label: 'CCTV y videovigilancia',
    svg: '<rect x="1.5" y="6" width="14" height="12" rx="2"/><path d="M15.5 10.5 22 7v10l-6.5-3.5Z"/>',
  },
  {
    label: 'Alarmas y control de acceso',
    svg: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="M9 12l2 2 4-4"/>',
  },
  {
    label: 'Instalaciones eléctricas',
    svg: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>',
  },
  {
    label: 'Energía solar',
    svg: '<circle cx="12" cy="12" r="4.5"/><line x1="12" y1="2" x2="12" y2="4.5"/><line x1="12" y1="19.5" x2="12" y2="22"/><line x1="4.2" y1="4.2" x2="5.9" y2="5.9"/><line x1="18.1" y1="18.1" x2="19.8" y2="19.8"/><line x1="2" y1="12" x2="4.5" y2="12"/><line x1="19.5" y1="12" x2="22" y2="12"/><line x1="4.2" y1="19.8" x2="5.9" y2="18.1"/><line x1="18.1" y1="5.9" x2="19.8" y2="4.2"/>',
  },
];
---

<Section theme="white" id="partner">
  <div class="mx-auto max-w-2xl text-center">
    <Eyebrow on="light">Aliado tecnológico</Eyebrow>
    <h2 data-reveal class="text-balance text-h2 font-semibold text-on-light">
      La infraestructura física, en manos de un aliado de confianza.
    </h2>
    <p data-reveal class="mt-4 text-lg leading-relaxed text-muted">
      <strong class="font-semibold text-on-light">Granular Electronics</strong> es
      la compañía hermana —fundada por el mismo equipo— que instala y mantiene
      la infraestructura física detrás de cada solución de AdariA.
    </p>
  </div>

  <div data-reveal class="mt-12 overflow-hidden rounded-3xl border border-ink/10 bg-light ring-1 ring-ink/5">
    <!-- Cabecera: logo, nombre y CTA en la misma línea (deja claro que es otra empresa) -->
    <div class="flex flex-col gap-6 border-b border-ink/10 p-8 sm:flex-row sm:items-center sm:justify-between sm:p-10">
      <div class="flex items-center gap-5">
        <div class="group flex h-20 w-20 shrink-0 items-center justify-center rounded-2xl border border-ink/10 bg-surface p-3.5 shadow-sm transition-shadow duration-300 hover:shadow-md">
          <img
            src="/partners/granular-electronics-logo.png"
            alt="Logo de Granular Electronics"
            class="h-full w-full object-contain transition-transform duration-500 ease-out group-hover:rotate-25 group-hover:scale-110"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div>
          <p class="text-lg font-semibold text-on-light">Granular Electronics</p>
          <p class="text-sm text-muted">Soluciones tecnológicas inteligentes · Cumaral, Meta</p>
        </div>
      </div>

      <Button
        href="https://granularelectronics.com"
        variant="secondary"
        on="light"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-fill-brand-hover shrink-0"
      >
        Visitar granularelectronics.com
      </Button>
    </div>

    <div class="grid gap-10 p-8 sm:p-10 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.4fr)] lg:gap-0 lg:p-0 lg:divide-x lg:divide-ink/10">
      <!-- Qué hace, en su propia voz -->
      <div class="lg:p-10">
        <p class="text-sm leading-relaxed text-muted">
          Instalación de redes de datos —cableado estructurado UTP y fibra
          óptica—, WiFi empresarial y suministro e instalación de equipos
          tecnológicos, más un portafolio de seguridad electrónica, energía
          solar e internet satelital, con cobertura en el Meta y los Llanos
          Orientales.
        </p>

        <dl class="mt-6 space-y-3 border-t border-ink/10 pt-6 text-sm">
          <div class="flex items-start gap-2.5">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-muted" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 21s-7-6.5-7-11a7 7 0 1 1 14 0c0 4.5-7 11-7 11Z" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="10" r="2.2" stroke="currentColor" stroke-width="1.6"/></svg>
            <dd class="text-on-light/85">Cumaral, Meta · Llanos Orientales, Colombia</dd>
          </div>
          <div class="flex items-start gap-2.5">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-muted" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.11 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.362 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0 1 22 16.92Z" stroke="currentColor" stroke-width="1.6"/></svg>
            <dd class="text-on-light/85">+57 320 465 1742</dd>
          </div>
        </dl>
      </div>

      <!-- Capacidades -->
      <div class="lg:p-10">
        <p class="text-xs font-semibold uppercase tracking-wide text-muted">Qué resuelve Granular</p>
        <ul class="mt-4 grid gap-2.5 sm:grid-cols-2">
          {capacidades.map((c) => (
            <li class="flex items-center gap-2.5 rounded-xl border border-ink/10 bg-surface px-4 py-3 text-sm font-medium text-on-light">
              <svg
                class="h-4.5 w-4.5 shrink-0 text-on-light/55"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.7"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                set:html={c.svg}
              />
              {c.label}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</Section>
