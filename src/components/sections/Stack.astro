---
// §9.4 — El stack integral de AdariA: 3 productos + servicios. Fondo claro.
import Section from '../ui/Section.astro';
import Eyebrow from '../ui/Eyebrow.astro';
import { productos } from '../../data/productos.ts';
---

<Section theme="light" id="productos">
  <div class="mx-auto max-w-3xl text-center">
    <Eyebrow on="light">El stack integral</Eyebrow>
    <h2 data-reveal class="text-h1 font-semibold text-on-light">
      Tres productos. Un solo aliado tecnológico.
    </h2>
    <p data-reveal class="mt-5 text-lg leading-relaxed text-muted">
      Software, visión artificial y hardware IoT que trabajan juntos —y se
      adaptan a tu operación con desarrollo a la medida.
    </p>
  </div>

  <div class="mt-16 grid gap-6 lg:grid-cols-3">
    {productos.map((p) => (
      <article data-reveal class="group flex flex-col rounded-2xl border border-ink/5 bg-surface p-8 shadow-sm transition-all hover:-translate-y-1 hover:shadow-lg">
        <div class="mb-4 flex items-center gap-3">
          <h3 class="text-2xl font-semibold text-on-light">{p.nombre}</h3>
          {p.badge && (
            <span class="rounded-full bg-brand/10 px-2.5 py-1 text-xs font-semibold text-brand">{p.badge}</span>
          )}
        </div>
        <p class="text-sm font-semibold text-brand">{p.tagline}</p>
        <p class="mt-3 text-sm leading-relaxed text-muted">{p.descripcion}</p>
        <ul class="mt-6 space-y-3 border-t border-ink/5 pt-6">
          {p.puntos.map((pt) => (
            <li class="flex items-start gap-2.5 text-sm text-on-light">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 10.5 8 14l8-8.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {pt}
            </li>
          ))}
        </ul>
        <a href="#contacto" class="mt-8 inline-flex items-center gap-1.5 text-sm font-semibold text-brand transition-colors group-hover:gap-2.5">
          Conocer más
          <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 10h12m0 0-5-5m5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </article>
    ))}
  </div>

  <p data-reveal class="mt-10 text-center text-sm text-muted">
    ¿Necesitas algo distinto? También hacemos
    <a href="#servicios" class="font-semibold text-brand hover:underline">desarrollo a la medida</a>.
  </p>
</Section>
