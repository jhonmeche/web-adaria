---
// §9.3 — La solución en pasos: Captar → Procesar → Decidir.
// Fondo BLANCO con una leve tinta azul (banda de "proceso"), para diferenciarla
// de la sección Industria 4.0 (oscura, justo antes) y de Stack (oscura, justo
// después) — alterna oscuro→blanco→oscuro desde el Hero. Se presenta como un
// diagrama de proceso.
import Section from '../ui/Section.astro';
import Eyebrow from '../ui/Eyebrow.astro';

const pasos = [
  {
    n: '01',
    titulo: 'Captar',
    texto: 'La visión artificial sobre las cámaras existentes y los sensores IoT/LoRa miden lo que pasa en planta, en tiempo real.',
    tags: ['Cámaras CCTV/IP', 'Sensores IoT', 'LoRa/LoRaWAN'],
    icon: 'M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Zm10 3a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z',
  },
  {
    n: '02',
    titulo: 'Procesar',
    texto: 'Modelos de IA y analítica en el borde convierten imágenes y señales en información útil y trazable.',
    tags: ['Edge computing', 'Modelos propios', 'Analítica'],
    icon: 'M6 4h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Zm4 5h4a1 1 0 0 1 1 1v4a1 1 0 0 1-1 1h-4a1 1 0 0 1-1-1v-4a1 1 0 0 1 1-1ZM9 2v2m6-2v2M9 20v2m6-2v2M2 9h2m-2 6h2m16-6h2m-2 6h2',
  },
  {
    n: '03',
    titulo: 'Decidir',
    texto: 'Dashboards, alertas y predicción ponen la decisión correcta frente a quien debe tomarla, a tiempo.',
    tags: ['Dashboards', 'Alertas', 'Predicción'],
    icon: 'M3 3v18h18M7 14l3-3 3 3 5-6',
  },
];
---

<Section
  theme="white"
  id="solucion"
  aria-labelledby="solucion-title"
  style="background-image: linear-gradient(180deg, #f1f4f8 0%, #ffffff 62%);"
>
  <div class="mx-auto flex max-w-3xl flex-col items-center text-center">
    <Eyebrow on="light">Del sensor a la decisión</Eyebrow>
    <h2 id="solucion-title" data-reveal class="text-balance text-h1 font-semibold text-on-light">
      Una sola cadena, de la captura a la decisión.
    </h2>
    <p data-reveal class="mt-5 max-w-2xl text-balance text-lg leading-relaxed text-muted">
      Integramos toda la cadena bajo un mismo techo. Capturamos el dato en campo,
      lo procesamos con inteligencia artificial y lo convertimos en decisiones
      accionables, trazables y auditables de principio a fin.
    </p>
  </div>

  <div class="relative mt-16">
    {/* Línea-cadena que conecta los tres pasos: el dato viaja de Captar a
       Decidir, con un pulso que recorre la línea en bucle (visible en los
       espacios entre cards). */}
    <div
      aria-hidden="true"
      class="absolute inset-x-[14%] top-1/2 hidden h-px -translate-y-1/2 overflow-hidden bg-linear-to-r from-transparent via-brand/25 to-transparent md:block"
    >
      <span class="flow-dot absolute inset-y-0 left-0 w-16 bg-linear-to-r from-transparent via-brand to-transparent"></span>
    </div>

    <ol class="grid gap-6 md:grid-cols-3">
      {pasos.map((p, i) => (
        <li
          data-reveal
          class="step group relative rounded-2xl border border-ink/10 bg-light p-8 ring-1 ring-ink/5 hover:-translate-y-1 hover:border-brand/40 hover:shadow-xl hover:shadow-brand/10"
          style={`--reveal-delay:${i * 90}ms`}
        >
          <div class="mb-6 flex items-center justify-between">
            <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-brand text-white shadow-lg shadow-brand/30">
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d={p.icon} stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
            <span aria-hidden="true" data-count={String(Number(p.n))} data-pad="2" class="inline-block origin-top-right text-6xl font-bold leading-none tracking-tight text-ink/10 transition-all duration-300 group-hover:scale-110 group-hover:text-brand/80">{p.n}</span>
          </div>
          <h3 class="mb-2 text-xl font-semibold text-on-light">{p.titulo}</h3>
          <p class="mb-5 text-sm leading-relaxed text-muted">{p.texto}</p>
          <ul class="flex flex-wrap gap-2">
            {p.tags.map((t) => (
              <li class="rounded-full border border-ink/10 bg-ink/5 px-3 py-1 text-xs text-on-light/75">{t}</li>
            ))}
          </ul>
          {i < pasos.length - 1 && (
            <div class="absolute -right-4 top-1/2 z-10 hidden h-8 w-8 -translate-y-1/2 items-center justify-center rounded-full bg-brand text-white shadow-lg shadow-brand/40 md:flex">
              <svg class="arrow-nudge h-4 w-4" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 10h12m0 0-5-5m5 5-5 5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
          )}
        </li>
      ))}
    </ol>
  </div>
</Section>

<style>
  /* Reveal escalonado por card: el fade se retrasa con --reveal-delay, mientras
     que la transición de hover (transform/sombra/borde) queda inmediata y ágil.
     Mayor especificidad que la regla global [data-reveal] para tomar el control. */
  .js [data-reveal].step {
    transform: none;
    transition:
      opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1) var(--reveal-delay, 0ms),
      transform 0.3s ease,
      box-shadow 0.3s ease,
      border-color 0.3s ease;
  }

  @media (prefers-reduced-motion: no-preference) {
    .arrow-nudge {
      animation: arrow-nudge 1.6s ease-in-out infinite;
    }
  }
  @keyframes arrow-nudge {
    0%, 100% { transform: translateX(-1.5px); }
    50% { transform: translateX(1.5px); }
  }
</style>
