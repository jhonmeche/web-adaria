---
// §9.3 — La solución en pasos: Captar → Procesar → Decidir. Fondo oscuro.
import Section from '../ui/Section.astro';
import Eyebrow from '../ui/Eyebrow.astro';

const pasos = [
  {
    n: '01',
    titulo: 'Captar',
    texto: 'Visión artificial sobre tus cámaras y sensores IoT/LoRa miden lo que pasa en planta, en tiempo real.',
    tags: ['Cámaras CCTV/IP', 'Sensores IoT', 'LoRa/LoRaWAN'],
    icon: 'M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Zm10 3a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z',
  },
  {
    n: '02',
    titulo: 'Procesar',
    texto: 'Modelos de IA y analítica en el borde convierten imágenes y señales en información útil y trazable.',
    tags: ['Edge computing', 'Modelos propios', 'Analítica'],
    icon: 'M9 3H5a2 2 0 0 0-2 2v4m6-6h6m-6 0v6m6-6h4a2 2 0 0 1 2 2v4m0 0v6m0-6h-6m6 6v-4a2 2 0 0 0-2-2m-12 6H5a2 2 0 0 1-2-2v-4m6 6v-6m0 6h6',
  },
  {
    n: '03',
    titulo: 'Decidir',
    texto: 'Dashboards, alertas y predicción ponen la decisión correcta frente a quien debe tomarla, a tiempo.',
    tags: ['Dashboards', 'Alertas', 'Predicción'],
    icon: 'M3 3v18h18M7 14l3-3 3 3 5-6',
  },
];
---

<Section theme="dark" id="solucion" grid={true}>
  <div class="mx-auto max-w-3xl text-center">
    <Eyebrow on="dark">Del sensor a la decisión</Eyebrow>
    <h2 data-reveal class="text-h1 font-semibold text-on-dark">
      Una sola cadena, de la captura a la decisión.
    </h2>
    <p data-reveal class="mt-5 text-lg leading-relaxed text-muted-dark">
      Cerramos el ciclo completo. Capturamos el dato, lo procesamos con IA y te
      lo devolvemos convertido en decisiones —con todo auditable.
    </p>
  </div>

  <div class="relative mt-16 grid gap-6 md:grid-cols-3">
    {pasos.map((p, i) => (
      <div data-reveal class="relative rounded-2xl border border-white/10 bg-ink-card p-8">
        <div class="mb-6 flex items-center justify-between">
          <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-brand/15 text-brand-400">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d={p.icon} stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
          <span class="text-4xl font-semibold text-white/10">{p.n}</span>
        </div>
        <h3 class="mb-2 text-xl font-semibold text-on-dark">{p.titulo}</h3>
        <p class="mb-5 text-sm leading-relaxed text-muted-dark">{p.texto}</p>
        <ul class="flex flex-wrap gap-2">
          {p.tags.map((t) => (
            <li class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-on-dark/80">{t}</li>
          ))}
        </ul>
        {i < pasos.length - 1 && (
          <div class="absolute -right-3 top-1/2 z-10 hidden h-6 w-6 -translate-y-1/2 items-center justify-center rounded-full bg-brand text-white md:flex">
            <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 10h12m0 0-5-5m5 5-5 5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
        )}
      </div>
    ))}
  </div>
</Section>
