---
// Header con navegación §7. En esta primera entrega (solo home) los ítems de
// los menús enlazan a las secciones de la home; cuando existan las landings
// dedicadas, basta cambiar los href a /soluciones/[slug], /productos/... etc.
import Logo from '../ui/Logo.astro';
import { sectores } from '../../data/sectores.ts';
import { productos } from '../../data/productos.ts';
import { servicios } from '../../data/servicios.ts';
---

<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-50 border-b border-white/10 bg-ink/84 backdrop-blur-xl transition-colors duration-300"
  data-header
>
  <!-- Barra de progreso de scroll: refuerzo discreto de la identidad técnica,
       se llena de izquierda a derecha con el avance de la página. -->
  <div class="pointer-events-none absolute inset-x-0 bottom-0 h-0.5 overflow-hidden bg-transparent" aria-hidden="true">
    <div id="scroll-progress" class="h-full w-0 bg-linear-to-r from-brand-400 to-brand"></div>
  </div>

  <nav class="mx-auto flex w-full max-w-7xl items-center justify-between px-5 py-3 lg:px-8" aria-label="Principal">
    <Logo variant="light" size="md" />

    <!-- Navegación desktop -->
    <ul class="hidden items-center gap-1 lg:flex">
      <!-- Soluciones -->
      <li class="group relative">
        <a href="/#sectores" class="nav-link" aria-haspopup="true">
          Soluciones
          <svg class="h-3.5 w-3.5 opacity-60 transition-transform group-hover:rotate-180" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M6 8l4 4 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <div class="dropdown">
          <p class="dropdown-title">Por sector</p>
          {sectores.map((s) => (
            <a href="/#sectores" class="dropdown-item">{s.nombre}</a>
          ))}
        </div>
      </li>

      <!-- Productos -->
      <li class="group relative">
        <a href="/#productos" class="nav-link" aria-haspopup="true">
          Productos
          <svg class="h-3.5 w-3.5 opacity-60 transition-transform group-hover:rotate-180" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M6 8l4 4 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <div class="dropdown">
          {productos.map((p) => (
            <a href={`/productos/${p.slug}`} class="dropdown-item">{p.nombre}</a>
          ))}
        </div>
      </li>

      <!-- Servicios -->
      <li class="group relative">
        <a href="/#servicios" class="nav-link" aria-haspopup="true">
          Servicios
          <svg class="h-3.5 w-3.5 opacity-60 transition-transform group-hover:rotate-180" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M6 8l4 4 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <div class="dropdown">
          {servicios.map((s) => (
            <a href={`/servicios/${s.slug}`} class="dropdown-item">{s.nombre}</a>
          ))}
        </div>
      </li>

      <li><a href="/blog" class="nav-link">Blog</a></li>
      <li><a href="/nosotros" class="nav-link">Nosotros</a></li>
      <li><a href="/#contacto" class="nav-link">Contacto</a></li>
    </ul>

    <!-- Botón menú móvil -->
    <button
      id="menu-toggle"
      class="inline-flex items-center justify-center rounded-lg p-2 text-on-dark lg:hidden"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
    </button>
  </nav>

  <!-- Menú móvil -->
  <div
    id="mobile-menu"
    class="hidden border-t border-white/10 bg-ink/95 backdrop-blur lg:hidden"
  >
    <div class="space-y-1 px-6 py-4">
      <a href="/#sectores" class="mobile-link">Soluciones</a>
      <a href="/#productos" class="mobile-link">Productos</a>
      <a href="/#servicios" class="mobile-link">Servicios</a>
      <a href="/blog" class="mobile-link">Blog</a>
      <a href="/nosotros" class="mobile-link">Nosotros</a>
      <a href="/#contacto" class="mobile-link">Contacto</a>
    </div>
  </div>
</header>

<style>
  @reference "../../styles/global.css";
  .nav-link {
    @apply inline-flex items-center gap-1 rounded-md px-3.5 py-2 text-sm font-medium text-on-dark/78 transition-colors hover:bg-white/[0.045] hover:text-on-dark;
  }
  .dropdown {
    @apply invisible absolute left-0 top-full min-w-64 translate-y-2 rounded-md border border-white/10 bg-ink/96 p-2 opacity-0 shadow-2xl backdrop-blur-xl transition-all duration-200;
  }
  .group:hover .dropdown,
  .group:focus-within .dropdown {
    @apply visible translate-y-1 opacity-100;
  }
  .dropdown-title {
    @apply px-3 pb-1.5 pt-2 text-xs font-semibold uppercase text-brand-400;
  }
  .dropdown-item {
    @apply block rounded-md px-3 py-2 text-sm text-on-dark/82 transition-colors hover:bg-white/[0.06] hover:text-on-dark;
  }
  .mobile-link {
    @apply block rounded-md px-2 py-2.5 text-base font-medium text-on-dark/90 transition-colors hover:bg-white/5 hover:text-on-dark;
  }

  /* Al desplegar el menú: los ítems entran escalonados (fade + desplazamiento),
     sin cambio de color en el texto. */
  @media (prefers-reduced-motion: no-preference) {
    .group:hover .dropdown-item,
    .group:focus-within .dropdown-item {
      animation: dropdown-item-in 0.45s ease backwards;
    }
    .group:hover .dropdown-item:nth-of-type(1),
    .group:focus-within .dropdown-item:nth-of-type(1) { animation-delay: 0.04s; }
    .group:hover .dropdown-item:nth-of-type(2),
    .group:focus-within .dropdown-item:nth-of-type(2) { animation-delay: 0.09s; }
    .group:hover .dropdown-item:nth-of-type(3),
    .group:focus-within .dropdown-item:nth-of-type(3) { animation-delay: 0.14s; }
    .group:hover .dropdown-item:nth-of-type(4),
    .group:focus-within .dropdown-item:nth-of-type(4) { animation-delay: 0.19s; }
    .group:hover .dropdown-item:nth-of-type(5),
    .group:focus-within .dropdown-item:nth-of-type(5) { animation-delay: 0.24s; }
  }

  @keyframes dropdown-item-in {
    0% {
      opacity: 0;
      transform: translateX(-8px);
    }
    100% {
      opacity: 1;
      transform: translateX(0);
    }
  }
</style>

<script>
  // Menú móvil
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
  });
  menu?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => {
      menu.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    }),
  );

  // Fondo del header al hacer scroll + barra de progreso de lectura
  const header = document.querySelector('[data-header]');
  const progress = document.getElementById('scroll-progress');
  const onScroll = () => {
    if (window.scrollY > 24) header?.classList.add('header-scrolled');
    else header?.classList.remove('header-scrolled');

    if (progress) {
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const pct = docHeight > 0 ? (window.scrollY / docHeight) * 100 : 0;
      progress.style.width = `${Math.min(100, Math.max(0, pct))}%`;
    }
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('resize', onScroll, { passive: true });
</script>

<style is:global>
  [data-header].header-scrolled {
    background-color: rgba(16, 20, 24, 0.94);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
</style>
