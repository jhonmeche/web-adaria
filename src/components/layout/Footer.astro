---
import Logo from '../ui/Logo.astro';
import { sectores } from '../../data/sectores.ts';
import { productos } from '../../data/productos.ts';

const year = new Date().getFullYear();
const servicios = [
  'Desarrollo de software',
  'Diseño de hardware',
  'Visión artificial e IA',
  'Soluciones IoT',
  'Integración y analítica',
];
---

<footer class="bg-ink text-on-dark">
  <div class="mx-auto max-w-6xl px-6 py-16 lg:px-8">
    <div class="grid gap-12 lg:grid-cols-[1.4fr_1fr_1fr_1fr]">
      <div>
        <Logo variant="light" />
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-muted-dark">
          Del sensor a la decisión, a la medida, con dato auditable. Visión
          artificial, IoT/LoRa y hardware propio bajo un mismo techo.
        </p>
        <p class="mt-4 text-sm text-muted-dark">Colombia · Latinoamérica</p>
      </div>

      <div>
        <h3 class="footer-title">Soluciones</h3>
        <ul class="space-y-2">
          {sectores.map((s) => (
            <li><a href="#sectores" class="footer-link">{s.nombre}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="footer-title">Productos</h3>
        <ul class="space-y-2">
          {productos.map((p) => (
            <li><a href="#productos" class="footer-link">{p.nombre}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="footer-title">Servicios</h3>
        <ul class="space-y-2">
          {servicios.map((s) => (
            <li><a href="#servicios" class="footer-link">{s}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-14 flex flex-col items-start justify-between gap-4 border-t border-white/10 pt-8 text-sm text-muted-dark sm:flex-row sm:items-center">
      <p>© {year} AdariA Systems. Todos los derechos reservados.</p>
      <div class="flex items-center gap-6">
        <a href="/blog" class="footer-link">Blog</a>
        <p class="text-muted-dark">Soluciones tecnológicas a la medida de tu industria.</p>
      </div>
    </div>
  </div>
</footer>

<style>
  @reference "../../styles/global.css";
  .footer-title {
    @apply mb-4 text-sm font-semibold text-on-dark;
  }
  .footer-link {
    @apply text-sm text-muted-dark transition-colors hover:text-on-dark;
  }
</style>
