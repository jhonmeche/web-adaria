---
// Diagrama: mini-dashboard ilustrativo. Muestra qué son KPIs, gráficas y alertas
// (es una maqueta visual, no datos reales).
interface Props {
  dark?: boolean;
}
const { dark = false } = Astro.props;

const box = dark ? 'border-white/10 bg-ink-card' : 'border-ink/10 bg-surface';
const tile = dark ? 'border-white/10 bg-ink/40' : 'border-ink/10 bg-light';
const title = dark ? 'text-on-dark' : 'text-on-light';
const muted = dark ? 'text-muted-dark' : 'text-muted';

const kpis = [
  { label: 'Disponibilidad', valor: '98,6%' },
  { label: 'Equipos OK', valor: '24/26' },
  { label: 'Alertas hoy', valor: '3' },
];
// Alturas relativas de las barras (maqueta).
const barras = [40, 62, 48, 75, 58, 84, 70];
---

<div class={`mt-10 rounded-2xl border p-6 sm:p-8 ${box}`} data-reveal>
  <div class="mb-5 flex items-center justify-between">
    <p class={`text-sm font-semibold ${title}`}>Así se ve un tablero (ejemplo)</p>
    <span class="inline-flex items-center gap-1.5 rounded-full bg-ok/15 px-2.5 py-0.5 text-xs font-medium text-ok">
      <span class="h-1.5 w-1.5 rounded-full bg-ok"></span> En vivo
    </span>
  </div>

  <!-- KPIs -->
  <div class="grid grid-cols-3 gap-3">
    {kpis.map((k) => (
      <div class={`rounded-xl border p-3 text-center ${tile}`}>
        <p class={`text-xl font-semibold ${title}`}>{k.valor}</p>
        <p class={`mt-0.5 text-[11px] leading-tight ${muted}`}>{k.label}</p>
      </div>
    ))}
  </div>

  <!-- Gráfica de barras (maqueta) + alerta -->
  <div class="mt-3 grid gap-3 sm:grid-cols-[1.6fr_1fr]">
    <div class={`rounded-xl border p-4 ${tile}`}>
      <p class={`mb-3 text-xs font-medium ${muted}`}>Vibración · últimos 7 días</p>
      <div class="flex h-24 items-end gap-2">
        {barras.map((h, i) => (
          <div
            class="flex-1 rounded-t bg-brand/80"
            style={`height:${h}%`}
            data-bar
            data-h={`${h}`}
          ></div>
        ))}
      </div>
    </div>

    <div class={`flex flex-col justify-center gap-2 rounded-xl border p-4 ${tile}`}>
      <div class="flex items-center gap-2 rounded-lg bg-ok/15 px-3 py-2 text-xs font-medium text-ok">
        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 10.5 8 14l8-8.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Temperatura normal
      </div>
      <div class="flex items-center gap-2 rounded-lg bg-warn/15 px-3 py-2 text-xs font-medium text-warn">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 9v4m0 4h.01M10.3 3.9 2.4 18a2 2 0 0 0 1.7 3h15.8a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Vibración en aumento
      </div>
    </div>
  </div>
</div>
