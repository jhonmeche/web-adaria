---
// Diagrama: flujo de la visión artificial. Cámara existente → modelo a la medida
// → eventos accionables (EPP, conteo, alertas).
interface Props {
  dark?: boolean;
}
const { dark = false } = Astro.props;

const box = dark ? 'border-white/10 bg-ink-card' : 'border-ink/10 bg-surface';
const title = dark ? 'text-on-dark' : 'text-on-light';
const muted = dark ? 'text-muted-dark' : 'text-muted';
const chip = dark ? 'border-white/10 bg-white/5 text-on-dark/85' : 'border-ink/10 bg-ink/5 text-on-light/80';
const conector = dark ? 'text-brand-400' : 'text-brand';

const pasos = [
  {
    t: 'sus cámaras',
    d: 'CCTV/IP actuales.',
    // Cámara industrial (caja de visión artificial): cuerpo, montura y lente centrado.
    icon: 'M3 8.5A1.5 1.5 0 0 1 4.5 7h15A1.5 1.5 0 0 1 21 8.5v7A1.5 1.5 0 0 1 19.5 17h-15A1.5 1.5 0 0 1 3 15.5v-7Z M10 7V5h4v2 M12 9.75a2.25 2.25 0 1 0 0 4.5 2.25 2.25 0 1 0 0-4.5Z',
  },
  {
    t: 'Modelo de IA',
    d: 'Entrenado a la medida de su operación.',
    // CPU simétrico (procesamiento del modelo en el borde).
    icon: 'M7 7h10v10H7zM10 10h4v4h-4zM9 4v3M15 4v3M9 17v3M15 17v3M4 9h3M4 15h3M17 9h3M17 15h3',
  },
  {
    t: 'Decisión',
    d: 'Eventos en tiempo real, auditables.',
    // Check en círculo (evento confirmado / auditable).
    icon: 'M12 3a9 9 0 1 0 0 18 9 9 0 1 0 0-18ZM8.5 12l2.5 2.5 4.5-5',
  },
];
const resultados = ['EPP detectado', 'Conteo', 'Defecto', 'Alerta'];
---

<div class={`mt-10 rounded-2xl border p-6 sm:p-8 ${box}`} data-reveal>
  <p class={`mb-6 text-sm font-semibold ${title}`}>Cómo "ve" la visión artificial</p>

  <div class="flex flex-col items-stretch gap-3 md:flex-row md:items-center">
    {pasos.map((p, i) => (
      <>
        <div class={`flex flex-1 items-center gap-3 rounded-xl border px-4 py-4 ${box}`}>
          <span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-brand text-white shadow-lg shadow-brand/30">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d={p.icon} stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
          <div>
            <p class={`text-sm font-semibold ${title}`}>{p.t}</p>
            <p class={`text-xs leading-snug ${muted}`}>{p.d}</p>
          </div>
        </div>
        {i < pasos.length - 1 && (
          <svg class={`mx-auto h-5 w-5 rotate-90 md:rotate-0 ${conector}`} viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 10h12m0 0-5-5m5 5-5 5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        )}
      </>
    ))}
  </div>

  <div class="mt-5 flex flex-wrap items-center gap-2 border-t border-current/10 pt-5">
    <span class={`text-xs font-medium ${muted}`}>Ejemplos de salida:</span>
    {resultados.map((r) => (
      <span class={`rounded-full border px-2.5 py-0.5 text-xs ${chip}`}>{r}</span>
    ))}
  </div>
</div>
