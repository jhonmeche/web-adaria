---
// Logo de marca: ícono viewfinder (recreado del logo oficial) + wordmark en texto.
// Renderizar el wordmark como texto permite adaptar el color sobre fondos
// claros u oscuros y mantenerlo nítido en cualquier tamaño.
interface Props {
  variant?: 'light' | 'dark'; // 'light' = para fondos oscuros; 'dark' = para fondos claros
  size?: 'md' | 'lg';
  class?: string;
}
const { variant = 'dark', size = 'md', class: className = '' } = Astro.props;
const wordmarkColor = variant === 'light' ? 'text-on-dark' : 'text-ink';
const strokeColor = variant === 'light' ? '#F5F7FA' : '#0C1116';
const iconSize = size === 'lg' ? 'h-14 w-14' : 'h-11 w-11';
const textSize = size === 'lg' ? 'text-2xl' : 'text-xl';
---

<a
  href="/"
  class={`group inline-flex items-center gap-2.5 ${className}`}
  aria-label="AdariA Systems — Inicio"
>
  <svg
    class={`${iconSize} shrink-0 transition-transform duration-300 group-hover:scale-105`}
    viewBox="0 0 64 64"
    fill="none"
    aria-hidden="true"
  >
    <g stroke={strokeColor} stroke-linecap="round" stroke-linejoin="round">
      {/* esquinas externas (más delgadas) */}
      <g stroke-width="3">
        <path d="M24 14 H17 a3 3 0 0 0 -3 3 V24" />
        <path d="M40 14 H47 a3 3 0 0 1 3 3 V24" />
        <path d="M24 50 H17 a3 3 0 0 1 -3 -3 V40" />
        <path d="M40 50 H47 a3 3 0 0 0 3 -3 V40" />
      </g>
      {/* mira central */}
      <g stroke-width="3">
        <path d="M21 32 H27" />
        <path d="M37 32 H43" />
        <path d="M32 21 V27" />
        <path d="M32 37 V43" />
      </g>
    </g>
    <circle cx="32" cy="32" r="3.6" fill="#00B4D8" />
  </svg>
  <span class={`${textSize} font-semibold leading-none tracking-tight ${wordmarkColor}`}>
    AdariA<span class="font-medium opacity-80"> Systems</span>
  </span>
</a>
