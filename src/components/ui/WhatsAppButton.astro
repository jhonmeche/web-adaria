---
// Botón flotante de WhatsApp (canal de contacto de baja fricción para venta B2B).
// Visible en todas las páginas. Aparece tras un pequeño scroll para no competir
// con el hero. Respeta accesibilidad (aria-label) y abre el chat en pestaña nueva.
//
// ⚠️ CONFIGURACIÓN: reemplaza NUMERO por el número real con código de país, sin
//    "+", espacios ni guiones. Colombia = 57 + número. Ej: 573001234567.
const NUMERO = '573138537266'; // WhatsApp de AdariA (Colombia: 57 + 313 853 7266)
const MENSAJE =
  'Hola, vengo del sitio web de AdariA Systems y quiero más información.';
const href = `https://wa.me/${NUMERO}?text=${encodeURIComponent(MENSAJE)}`;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  data-wsp
  class="group fixed bottom-6 right-6 z-50 flex items-center gap-2.5 rounded-full bg-[#25D366] py-3.5 pl-3.5 pr-4 text-white shadow-xl shadow-black/25 transition-all duration-300 hover:-translate-y-0.5 hover:bg-[#1ebe5d] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#25D366]"
  aria-label="Escríbenos por WhatsApp"
>
  <svg class="h-7 w-7 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.51 5.26l-.999 3.648 3.477-.305zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413z"/>
  </svg>
  <span class="hidden text-sm font-semibold sm:inline">¿Hablamos?</span>
</a>

<style>
  /* Entra cuando ya se hizo scroll (se controla con la clase del <html>). */
  [data-wsp] {
    opacity: 0;
    transform: translateY(12px) scale(0.96);
    pointer-events: none;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  :global(html.wsp-show) [data-wsp] {
    opacity: 1;
    transform: none;
    pointer-events: auto;
  }
  /* Sin JS, el botón siempre se muestra (mejora progresiva). */
  :global(html:not(.js)) [data-wsp] {
    opacity: 1;
    transform: none;
    pointer-events: auto;
  }
</style>

<script>
  // Muestra el botón tras un pequeño scroll para no tapar el hero al entrar.
  const root = document.documentElement;
  const onScroll = () => {
    if (window.scrollY > 320) root.classList.add('wsp-show');
    else root.classList.remove('wsp-show');
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>
