---
// Etiqueta pequeña sobre los titulares de sección. El acento azul solo aquí
// como detalle (nunca en texto de párrafo).
interface Props {
  on?: 'dark' | 'light';
  class?: string;
}
const { on = 'light', class: className = '' } = Astro.props;
const color = on === 'dark' ? 'text-brand-400' : 'text-brand';
---
<p class={`mb-4 inline-flex items-center gap-2 text-sm font-medium tracking-tight ${color} ${className}`}>
  <span class="h-px w-6 bg-current opacity-60"></span>
  <slot />
</p>
