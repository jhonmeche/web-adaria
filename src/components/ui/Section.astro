---
// Envoltorio de sección. `theme` alterna el fondo para dar ritmo a la home
// (§13): oscuro (bg-ink) → blanco (bg-surface) → gris (bg-light) → oscuro...
// Incluye padding vertical generoso ("mucho aire").
interface Props {
  theme?: 'dark' | 'light' | 'white';
  id?: string;
  class?: string;
  /** Activa la rejilla técnica sutil (solo tiene sentido en theme oscuro). */
  grid?: boolean;
  /** Atributos HTML extra reenviados al <section> (p. ej. aria-labelledby). */
  [key: string]: unknown;
}
const { theme = 'light', id, class: className = '', grid = false, ...rest } = Astro.props;
const bg =
  theme === 'dark' ? 'bg-ink text-on-dark' : theme === 'white' ? 'bg-surface text-on-light' : 'bg-light text-on-light';
---

<section id={id} class={`relative overflow-hidden ${bg} ${className}`} {...rest}>
  {grid && <div class="tech-grid pointer-events-none absolute inset-0 opacity-45" aria-hidden="true"></div>}
  <div class="relative mx-auto w-full max-w-7xl px-6 py-18 sm:py-24 lg:px-8">
    <slot />
  </div>
</section>
